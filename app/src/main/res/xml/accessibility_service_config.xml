<?xml version="1.0" encoding="utf-8"?>
<!--
  Pause is deliberately the most minimal accessibility service possible:
   - It listens for ONE event type: a change in which window/app is in the foreground.
   - canRetrieveWindowContent is FALSE — Pause never reads on-screen text or content.
   - packageNames is intentionally left unset so the service is told about EVERY foreground
     change and filters in code. This is required for correctness: to reset the timer when the
     user leaves a monitored app we must be notified of the switch to the (non-selected) app
     they moved to. Either way the only thing Pause can ever observe is a foreground package
     name — never screen content.
   - notificationTimeout=0 so no foreground transition is coalesced/debounced away.
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagDefault"
    android:canRetrieveWindowContent="false"
    android:notificationTimeout="0"
    android:description="@string/accessibility_service_description"
    android:summary="@string/accessibility_service_summary" />
