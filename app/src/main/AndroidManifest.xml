<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Draw the full-screen interruption overlay on top of the app being scrolled (always needed). -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!--
      Usage Access (default detection mode): read which app is in the foreground and for how long.
      The user grants this via Settings → "Usage access"; only the foreground package name + timing
      are ever read, and nothing leaves the device.
    -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- The Usage-Access detector runs as a small foreground service (special use). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- Show the foreground-service status notification on Android 13+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      Make the catalogued apps visible (Android 11+ package visibility) so Pause can show their
      real launcher icons in the picker. We do NOT request QUERY_ALL_PACKAGES — only these specific,
      named packages are queryable, and Pause only ever reads their icon/label.
    -->
    <queries>
        <package android:name="com.instagram.android" />
        <package android:name="com.zhiliaoapp.musically" />
        <package android:name="com.google.android.youtube" />
        <package android:name="com.reddit.frontpage" />
        <package android:name="com.twitter.android" />
        <package android:name="com.facebook.katana" />
        <package android:name="com.snapchat.android" />
    </queries>

    <application
        android:name=".PauseApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.Pause"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Pause.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          The heart of the product. The system binds this service to deliver foreground-app
          change events. We only read the package name of the active window — never its
          content — to know when a monitored app has been on screen long enough to interrupt.
        -->
        <service
            android:name=".service.PauseAccessibilityService"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!--
          The default detector: a small foreground service that reads the foreground app via Usage
          Access. It reads only the foreground package name + timing — never screen content — and
          nothing leaves the device.
        -->
        <service
            android:name=".service.UsageAccessMonitorService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Detects which app is in the foreground via Usage Access to interrupt long scrolling sessions. No data leaves the device." />
        </service>

    </application>

</manifest>
